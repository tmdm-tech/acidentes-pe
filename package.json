{
  "name": "observape-ios-wrapper",
  "version": "1.0.0",
  "private": true,
  "description": "Empacotamento iOS (Capacitor) para o ObservaPE",
  "scripts": {
    "sync:web": "bash scripts/sync_web_for_ios.sh",
    "ios:init": "npx cap add ios",
    "ios:sync": "npm run sync:web && npx cap sync ios",
    "ios:open": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/core": "^6.1.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2"
  }
}
